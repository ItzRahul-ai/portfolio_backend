PORT=5000
NODE_ENV=development

# Atlas SRV connection string (recommended)
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/portfolioDB?retryWrites=true&w=majority
# Optional: non-SRV fallback URI
MONGO_URI_FALLBACK=
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
# Optional additional origins (comma separated)
CORS_ORIGINS=
# Allow all Vercel preview URLs (*.vercel.app)
ALLOW_VERCEL_PREVIEWS=false
FRONTEND_URL=

ADMIN_EMAIL=admin@example.com
ADMIN_NAME=Portfolio Admin
ADMIN_PHONE=+911234567890
ADMIN_INITIAL_PASSWORD=replace_with_admin_password

EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=dipCoder <your_email@gmail.com>

TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155238886
